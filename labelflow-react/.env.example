# LabelFlow Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your .env file — it is already in .gitignore.

# ------------------------------------------------------------------
# Optional: OpenAI API key for live AI content generation.
# If not set, the app uses simulated AI responses (fully functional).
# Get your key at: https://platform.openai.com/api-keys
# ------------------------------------------------------------------
VITE_OPENAI_API_KEY=

# ------------------------------------------------------------------
# Optional: Custom app name displayed in the UI.
# ------------------------------------------------------------------
VITE_APP_NAME=LabelFlow
